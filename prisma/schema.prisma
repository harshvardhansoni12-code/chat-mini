generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  CreatedAt DateTime @default(now())
}

model Room {
  id String @id @default(uuid())
  roomname String 
  roomcode String @unique
  CreatedAt DateTime @default(now())
  deletedAt DateTime ?
  }
  